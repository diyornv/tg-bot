# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/moviebot

# Private channel where movies are uploaded
# The bot MUST be an admin in this channel
MOVIE_CHANNEL_ID=-1001234567890

# Super Admin Telegram ID (your personal Telegram numeric ID)
SUPER_ADMIN_ID=123456789

# Rate Limit: max requests per window
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=10000
